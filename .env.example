cat > .env.example <<'EOF'
APP_NAME=SagesAI
APP_VERSION=0.1.0
ENVIRONMENT=development

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=sagesai
DATABASE_USER=sagesai
DATABASE_PASSWORD=change_me

SECRET_KEY=replace_with_a_secure_random_secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
EOF